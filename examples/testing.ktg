Kintsugi []

; --- Data Processing with Parse ---
; Multi-line string, parse dialect for extraction,
; objects for structure, sort/by for ranking.

raw: {Alice,90,85,92
Bob,78,82,88
Charlie,95,91,87
Diana,88,94,96}

StudentRecord: object [
  name [string!]
  scores [block!] @default []
  average: function [] [
    total: 0
    loop [for [s] in self/scores do [total: total + s]]
    total / (length self/scores)
  ]
]

records: parse raw [
  collect [
    some [
      context [
        name: keep to "," skip
        s1: keep to "," skip
        s2: keep to "," skip
        s3: keep to ["\n" | end] opt "\n"
      ]
    ]
  ]
]

students: loop/collect [
  for [record] in records do [
    make StudentRecord [
      name: record/name
      scores: reduce [
        to integer! record/s1
        to integer! record/s2
        to integer! record/s3
      ]
    ]
  ]
]

ranked: sort/by students function [s] [negate s/average]
loop [
  for [s] in ranked do [
    print rejoin ["  " s/name " — avg: " round s/average]
  ]
]

; Diana — avg: 93
; Charlie — avg: 91
; Alice — avg: 89
; Bob — avg: 83
