; ============================================================
; Learn Kintsugi in Y Minutes
; ============================================================
;
;
; Kintsugi is a homoiconic, dynamically-typed programming
; language with rich built-in datatypes, compile-time
; evaluation, and a number of useful facilities powered by
; DSLs called "dialects".
;
; Influenced by REBOL, Red, Ren-C, Common Lisp, D, and Raku.
;
; Tier hierarchy:
;
;   Kintsugi/Core         - core types, words, blocks
;   Kintsugi/Systems      - adds strings, logic, headers
;   Kintsugi/Full         - adds dialects
;   Kintsugi/Exports      - adds AST to (WASM, JS, native code)
;
; File extensions:
;   .ktg - For all source files.
;
; ============================================================


; ============================================================
; HEADER DIALECT
; ============================================================
; Every Kintsugi program begins with a header block.
; The header word is the tier: Kintsugi (short for
; Kintsugi/Full), Kintsugi/Core, Kintsugi/Systems, etc.
;
; Dialect keywords:
;   name:         - module name (lit-word)
;   date:         - creation or last-modified date
;   file:         - the source file
;   version:      - semantic version (tuple!)
;   permissions:  - required system permissions
;   modules:      - dependencies (see below)
;   paths:        - additional module search paths
;
; The modules: field lists dependencies. Two forms:
;   'lit-word  - a built-in dialect (required from standard library)
;   %file      - a module entrypoint (required from file path)
;
; Each entry is required and bound into the current scope
; using the name from its header block.

Kintsugi [
  name: 'full-spec
  date: 2026-02-26
  file: %full-spec.ktg
  version: 0.1.0
  permissions: ['system 'network 'file]
  modules: ['view %api.ktg %parse.ktg]
  paths: [%extra-modules/]
]


; ============================================================
; DATATYPES
; ============================================================
; Kintsugi has many built-in datatypes. Every value carries
; its type at runtime. Type names are suffixed with !

; --- Scalars ---

my-int: 42                              ; integer!
negative: -7                            ; integer!
my-float: 3.14                          ; float!
my-char: #"A"                           ; char!
my-pair: 100x200                        ; pair! (2D coordinates)
my-money: $19.99                        ; money!
my-version: 1.2.3                       ; tuple! (versions, colors, IPs)

; --- Logic ---
; Multiple aliases for true/false

a: true                                 ; logic!
b: false
c: on                                   ; same as true
d: off                                  ; same as false
e: yes                                  ; same as true
f: no                                   ; same as false

; --- None ---

empty: none                             ; none! (null/nil)

; --- Temporal ---

my-date: 2026-02-26                     ; date!
short-date: 26-02-26                    ; date! (short form)
my-time: 14:30:00                       ; time!

; --- Text & Markup ---

my-string: "Hello, world"              ; string!
escaped: "Line one^/Line two"          ; ^/ is newline escape
my-binary: #{48656C6C6F}               ; binary! (hex encoded)

; --- Identifiers & Resources ---

my-file: %path/to/file.txt             ; file!
my-dir: %extra-modules/                ; file!
my-url: https://example.com/api        ; url!
my-email: user@example.com             ; email!

; --- I/O ---
; port! is a runtime-only type — no literal syntax.
; open a url! to get a port!. The url scheme determines
; the port behavior (tcp, http, file, etc.)

my-port: open tcp://localhost:8080      ; port!

; --- Composite ---

my-block: [1 2 "three" 4.0]            ; block! (the universal container)
nested: [[1 2] [3 4] [5 6]]            ; blocks nest freely
code-as-data: [print "I am data"]      ; code is just a block
my-paren: (1 + 2)                       ; paren! — evaluates at top level
                                        ; result is 3, not a paren! value
                                        ; inside a block, parens are inert
                                        ; data like everything else


; ============================================================
; WORDS
; ============================================================
; Words are the primary identifiers. A prefix or suffix on
; the word controls how it evaluates.

name: "Kintsugi"                        ; set-word  (bind a value)
; name                                  ; word      (evaluate / lookup)
ref: :name                              ; get-word  (get without calling)
sym: 'name                              ; lit-word  (the symbol itself)

; Words can contain letters, digits, hyphens, ?, !, _, ~
is-valid?: true
my-variable!: 42


; ============================================================
; BINDING & CONTEXTS
; ============================================================
; Kintsugi uses Rebol-style context binding.
; Every word carries a binding to a specific context.
; There is no lexical scope — words are bound, not scoped.
;
; Contexts are created by:
;   function  - parameters and local words
;   object    - named fields
;   use       - anonymous local context
;
; bind explicitly rebinds words to a different context.

; object creates a context
point: object [x: 10 y: 20]
point/x                                 ; => 10

; use creates an anonymous local context
use [temp] [
  temp: expensive-computation
  process temp
]
; temp is not visible here

; bind rebinds words to a context
code: [x + y]
bind code point                         ; x and y now resolve in point
do code                                 ; => 30


; ============================================================
; TYPESETS
; ============================================================
; Typesets group related types for polymorphism and
; type checking. They are values themselves.
;
; Built-in typesets:
;   number!     = integer! | float!
;   any-word!   = word! | set-word! | get-word! | lit-word!
;   any-block!  = block! | paren! | path!
;   series!     = string! | block! | file! | url!
;                 | email! | binary!
;   scalar!     = integer! | float! | date! | time!
;                 | money! | pair! | tuple! | char!
;   port!       = live I/O handle (runtime only, no literal)
;   any-type!   = all types

; Custom typesets
coordinate!: typeset [pair! block!]
response!: typeset [string! block! none!]

; Type introspection
type? 42                                ; => integer!
type? "hello"                           ; => string!
type? [1 2 3]                           ; => block!
type? :add                              ; => function!
type? my-port                           ; => port!

; Type predicates
integer? 42                             ; => true
number? 3.14                            ; => true
series? "abc"                           ; => true
none? none                              ; => true

; Type conversion (explicit only - no implicit coercion)
to integer! "42"                        ; => 42
to string! 42                           ; => "42"
to float! 7                             ; => 7.0
to block! "hello"                       ; => ["hello"]
to logic! 0                             ; => false
to logic! 1                             ; => true


; ============================================================
; FUNCTION DIALECT
; ============================================================
; The spec block inside 'function' is a dialect. Words,
; type blocks, refinements, and return: have special meaning.
;
; Dialect keywords:
;   [type!]    - type constraint on the preceding parameter
;   /refine    - refinement (optional named behavior)
;   return:    - declares the return type

; Basic definition
add: function [a b] [
  a + b
]

; Type constraints and return type
add-typed: function [a [integer!] b [integer!] return: [integer!]] [
  a + b
]

; Polymorphic via typesets
double: function [value [number!]] [
  value * 2
]

; Refinements add optional behavior
greet: function [name [string!] /loud /times count [integer!]] [
  message: "Hello, " + name
  if loud [message: uppercase message]
  either times [
    repeat count [print message]
  ] [
    print message
  ]
]

; Calling with refinements
greet "world"                           ; => Hello, world
greet/loud "world"                      ; => HELLO, WORLD
greet/loud/times "world" 3             ; => HELLO, WORLD (x3)

; Functions are first-class values
operation: :add                         ; get-word grabs the function value
operation 3 4                           ; => 7


; ============================================================
; LAMBDAS
; ============================================================
; -> is an infix operator that creates a function.
; Left side: parameter word(s). Right side: body.
; The enclosing paren delimits the body and forces evaluation,
; yielding a function! value.
;
; Use 'function' for named definitions with type constraints.
; Use (params -> body) for inline/anonymous functions.

; Single parameter — paren forces evaluation, delimits body
map my-list (n -> n * 2)

; Multiple parameters
reduce my-list 0 (acc n -> acc + n)

; Named lambda
my-transform: (n -> n * 2)
map my-list my-transform

; Passing lambdas to higher-order functions
filter my-list (n -> n > 50)
sort/with my-list (a b -> a - b)

; Lambdas work anywhere a function is expected
(x -> x * x) 5                         ; => 25

; Multi-line bodies — the paren spans multiple lines
process: (item ->
  cleaned: trim item
  validated: validate cleaned
  store validated
)

; ============================================================
; BLOCKS & HOMOICONICITY
; ============================================================
; Code is data. Data is code. Everything is a block.
;
; Blocks [ ] are inert — they hold code or data without
; evaluating it. Nothing inside a block evaluates, not even
; parens. Parens ( ) evaluate at the top level or inside do,
; but inside a block literal they are just data.
;
; compose walks a block and selectively evaluates parens,
; replacing them with the results. Everything else stays as
; data. This is how you build code from templates.

data: [print "Hello"]

; Inspect code as data
length? data                            ; => 2
first data                              ; => 'print (a word)
second data                             ; => "Hello" (a string)

; Modify code as data
append data " world"

; Execute data as code
do [print "I was data, now I am running"]

; Blocks vs parens
inert: [1 + 2]                          ; block! — held as data: [1 + 2]
eager: (1 + 2)                          ; evaluates here (top level): 3

; Compose - build blocks from templates
; compose evaluates parens and substitutes the results.
; Everything else in the block stays as inert data.
target: "Alice"
code: compose [greet (target) 42]       ; => [greet "Alice" 42]
do code


; ============================================================
; RANGES & SEQUENCES
; ============================================================
; Inspired by D language ranges. Sequences can be lazy
; (computed on demand) or eager (materialized).

; Basic ranges
r1: range 1 10                          ; 1 through 10
r2: range/by 10 1 -1                   ; 10 down to 1, step -1
r3: range/by 0 100 5                   ; 0, 5, 10, ... 100

; Lazy sequences (nothing computed until consumed)
squares: loop/lazy [
  for [x]
  in range 1 1000000
  do [x * x]
]

; Materialize only what you need
take squares 5                          ; => [1 4 9 16 25]

; Sequence combinators
zipped: zip [r1 r2]                     ; [[1 10] [2 9] [3 8] ...]
chained: chain [r1 r2 r3]              ; concatenates end-to-end

; Zip operator (infix)
test-case1: [1 2 3 4]
test-case2: [5 6 7 8]
print test-case1 Z test-case2           ; zips pairs

; Lazy with guard clause
evens: loop/lazy [
  for [x]
  in range 1 100
  when [x % 2 = 0]
  do [x]
]

; Multi-variable iteration
products: loop/lazy [
  for [a b]
  in range 1 10
  do [a * b]
]



; ============================================================
; CONTROL FLOW
; ============================================================

; if (single branch - returns result or none)
if x > 10 [print "big"]

; either (two branches - always returns a value)
either x > 10 [
  print "big"
] [
  print "small"
]

; unless (negated if)
unless empty? collection [
  process collection
]

; while
while [x > 0] [
  print x
  x: x - 1
]

; repeat (fixed count)
repeat 5 [print "hello"]

; forever (infinite loop - break to exit)
forever [
  data: read-input
  if data = "quit" [break]
  process data
]


; ============================================================
; LOOP DIALECT
; ============================================================
; The block inside 'loop' is a dialect. These words have
; special meaning inside the loop block:
;
; Dialect keywords:
;   for    - declare iteration variable(s)
;   in     - the series to iterate over
;   when   - guard clause (filter)
;   do     - the loop body

; for-each over a series
loop [
  for [item]
  in [1 2 3 4 5]
  do [print item]
]

; for-each with index
loop [
  for [item index]
  in ["a" "b" "c"]
  do [print index + ": " + item]
]


; ============================================================
; MATCH DIALECT
; ============================================================
; match tests a value against a series of patterns.
; First match wins. Patterns can destructure and bind.
; The pattern block is a dialect with its own binding rules.
;
; Dialect keywords:
;   bare word  - captures/binds the value at this position
;   (expr)     - evaluate expression, match against result
;   'word      - matches the literal word (useful for errors)
;   literal    - matches exactly (integers, strings, etc.)
;   _          - wildcard (matches anything, doesn't bind)
;   when       - guard clause (additional condition)
;   default:   - fallback if nothing matched

; Literal matching
match value [
  [1 2 3]  [print "got 1 2 3"]
  [1 _ 3]  [print "1, anything, 3"]    ; _ is wildcard
  [_]      [print "catch-all"]
  default: [print "nothing matched"]
]

; Destructuring - bare words capture values
match point [
  [0 0]   [print "origin"]
  [x 0]   [print "x-axis at " + x]     ; x captures, 0 is literal
  [0 y]   [print "y-axis at " + y]     ; 0 is literal, y captures
  [x y]   [print x + ", " + y]         ; both capture
]

; Parens evaluate and match against the result
expected: 42
match result [
  [(expected)]   [print "got what we expected"]
  [(x + 1)]     [print "matched x + 1"]
  [x]           [print "got " + x + " instead"]
]

; Lit-words match the word itself (useful for error names)
match error-name [
  ['division-by-zero]  [print "math error"]
  ['unreachable]       [print "network error"]
  [_]                  [print "unknown error"]
]

; Guards - additional conditions on a match
match age [
  [n] when [n < 13]  [print "child"]
  [n] when [n < 20]  [print "teenager"]
  [n] when [n < 65]  [print "adult"]
  [_]                [print "senior"]
]


; ============================================================
; SCOPE DIALECT
; ============================================================
; Lifecycle hooks that fire at specific scope boundaries.
; scope is a dialect accessed via path syntax.
;
; Dialect keywords:
;   scope/enter  - runs when entering a scope
;   scope/exit   - runs when leaving a scope
;   scope/first  - runs before the first loop iteration
;   scope/last   - runs after the last loop iteration

; --- Scope hooks ---

if condition [
  scope/enter [
    resource: acquire-lock "database"
  ]
  scope/exit [
    release-lock resource
  ]

  ; Body runs between scope/enter and scope/exit
  result: query resource "SELECT * FROM users"
  print result
]

; scope/exit always runs, even on error.
; Scope hooks compose across nested scopes.

; --- Loop hooks ---

loop [
  for [item]
  in collection
  scope/first [print "=== Begin Processing ==="]
  scope/last  [print "=== Done Processing ==="]
  do [process item]
]


; ============================================================
; PARSE DIALECT
; ============================================================
; Rebol-style rule-based parsing. Parse operates on series
; (strings, blocks) using grammar rules defined as blocks.

; --- String parsing ---

email-text: "user@example.com"

parse email-text [
  copy name some [alpha | digit | "." | "-"]
  "@"
  copy domain some [alpha | digit | "." | "-"]
]
; name => "user", domain => "example.com"

; --- Block parsing ---

data: [name "Alice" age 25 role "admin"]

parse data [
  some [
    'name copy who string!
    | 'age copy years integer!
    | 'role copy job string!
  ]
]
; who => "Alice", years => 25, job => "admin"

; --- Composable rules ---
; Rules are blocks. Blocks are data. So rules compose.

digit-run: [some digit]

date-rule: [
  copy year digit-run "-"
  copy month digit-run "-"
  copy day digit-run
]

parse "2026-02-26" date-rule
; year => "2026", month => "02", day => "26"

; Dialect keywords:
;   some   - one or more matches
;   any    - zero or more matches
;   opt    - zero or one match
;   copy   - capture matched input into a word
;   to     - advance to (not past) a match
;   thru   - advance through (past) a match
;   not    - fail if the rule matches
;   ahead  - lookahead without consuming input
;   end    - match end of input
;   skip   - match any single element
;   |      - ordered alternative


; ============================================================
; SHAPES & VALIDATION
; ============================================================
; Shapes are parse rules used as lightweight data contracts.
; By convention, shape names use the ~ suffix to distinguish
; them from built-in runtime types (!).
;
; is? takes any value and a parse rule, returns logic!.
; It's just sugar for parse — no new type system, no overhead
; beyond a single parse call.

; --- Defining shapes ---

user~: ['name string! 'age integer! 'roles block!]
account~: ['name string! 'balance number!]

; --- Validating with is? ---

is? [name "Alice" age 25 roles ["admin"]] user~
; => true

is? [name "Alice"] user~
; => false (missing fields)

; --- Composable shapes ---
; Shapes are blocks. Blocks are data. So shapes compose.

base~: ['name string! 'age integer!]
admin~: [base~ 'permissions block!]

; --- Guard patterns ---

process-user: function [u [block!]] [
  unless is? u user~ [
    error 'invalid-shape "expected user"
  ]
  print u/name
]

; --- is? works on any value and any parse rule ---

is? "2026-02-26" [some digit "-" some digit "-" some digit]
; => true

is? email-text [
  some [alpha | digit | "." | "-"]
  "@"
  some [alpha | digit | "." | "-"]
]
; => true


; ============================================================
; ERROR HANDLING
; ============================================================
; Lua-style protected calls. Simple and predictable.
;
;   try         - call a block safely, get back [logic! result]
;   try/handle  - same, but with a custom error handler
;
; Errors are raised with 'error'. Unprotected errors
; crash the runtime.

; --- Raising errors ---
; error takes a lit-word (the error name) and an optional
; string message. The lit-word gives you something matchable.

safe-divide: function [x [number!] y [number!]] [
  if y = 0 [error 'division-by-zero "cannot divide by zero"]
  x / y
]

validate: function [age [integer!]] [
  if age < 0 [error 'invalid-age "age cannot be negative"]
  if age > 150 [error 'invalid-age "age seems unrealistic"]
  age
]

; Message is optional - the lit-word alone is enough
check-connection: function [host [url!]] [
  if not reachable? host [error 'unreachable]
]

; --- try (protected call) ---
; Calls a block in protected mode. Returns a block:
;   [true result]        on success
;   [false name message] on failure (name is the lit-word)

result: try [safe-divide 10 2]
; result => [true 5]

result: try [safe-divide 10 0]
; result => [false 'division-by-zero "cannot divide by zero"]

; Check and use the result
either first result [
  print "Got: " + second result
] [
  print "Error: " + second result + " - " + third result
]

; --- try/handle (protected call with handler) ---
; Like try, but with a custom error handler function.
; The handler receives the error name and message.

log-handler: function [name [lit-word!] message [string!]] [
  print "Caught " + name + ": " + message
  0
]

result: try/handle [safe-divide 10 0] :log-handler
; prints "Caught division-by-zero: cannot divide by zero"
; result => [false 0]

; --- Nested protection ---

result: try [
  inner: try [risky-operation]
  either first inner [
    process second inner
  ] [
    error 'inner-failure "inner operation failed"
  ]
]

; However, this can be a more verbose way of handling this.
; For that reason, we have...

; ============================================================
; ATTEMPT DIALECT
; ============================================================
; A dialect for chaining operations and handling errors.
; Use do/then to build pipelines. Add error handling
; when you need to. then binds the previous result to 'it'.
;
; Dialect keywords:
;   do       - the initial operation
;   then     - chain the next step (previous result is 'it')
;   it       - the previous step's result
;   on       - handle a named error
;   retries  - how many times to retry on error
;   delay    - ms between retries
;   fallback - last resort if everything fails

; --- Simple pipeline (no error handling) ---
; do starts the chain. Each then block receives the
; previous result as 'it'.

result: attempt [
  do   [range 1 100]
  then [map it (n -> n * 2)]
  then [filter it (n -> n > 50)]
  then [take it 10]
  then [reduce it 0 (acc n -> acc + n)]
]

cleaned: attempt [
  do   ["  Hello, World  "]
  then [trim it]
  then [lowercase it]
  then [split it ", "]
]

; The nested try example from above becomes...

result: attempt [
  do   [risky-operation]
  then [process it]
  on 'inner-failure [print "inner operation failed"]
]

; --- With error handling ---

result: attempt [
  do    [http/get my-url]
  on 'unreachable [print "host down" none]
]

; --- Retry policies ---

result: attempt [
  do      [http/get my-url]
  retries 3
  delay   1000                          ; ms between retries
  on 'unreachable [
    print "retrying..."
  ]
  fallback [none]
]

; --- Multiple handlers ---

result: attempt [
  do [
    response: http/get my-url
    parse-json response/body
  ]
  retries 2
  on 'unreachable   [print "network down" none]
  on 'parse-error   [print "bad json" []]
  fallback [error 'fetch-failed "all retries exhausted"]
]

; --- Full pipeline with error handling ---
; Each step only runs if the previous succeeded.

result: attempt [
  do    [connect database-url]
  then  [query it "SELECT * FROM users"]
  then  [map it (row -> parse-user row)]
  on 'connection-failed [print "db down" []]
  on 'query-error       [print "bad query" []]
  fallback [[]]
]


; ============================================================
; COMPILE-TIME EVALUATION
; ============================================================
; #comptime evaluates a block at compile time.
; The block receives code-as-data and emits code-as-data.

; --- Conditional compilation ---

#comptime [
  either platform = 'windows [
    print "Running on Windows"
  ] [
    print "Running on Linux"
  ]
]

; --- Compile-time constants ---

#comptime [
  max-connections: 100
  build-date: 2026-02-26
]

; --- Code generation ---
; Comptime can be used to generate repetitive code from data.

#comptime [
  for-each field [name age email] [
    emit compose [
      (to set-word! join "get-" field) function [obj] [
        select obj (to lit-word! field)
      ]
    ]
  ]
]

; --- Conditional includes ---

#comptime [
  if platform = 'windows [
    require %windows-support.ktg
  ]
]


; ============================================================
; REQUIRE & FILE-BASED MODULES
; ============================================================
; There is no module system. Any valid Kintsugi program can
; be used as a module. require is a word (not a directive)
; that reads a file, resolves its header dependencies,
; evaluates the body in an isolated context, and returns
; the resulting namespace as a block.
;
; The header is consumed by require — it is not part of
; the returned namespace. Access module contents via path
; syntax. The caller decides what word to bind the module to.
;
; Refinements:
;   /header  - return the header block instead of the namespace

; --- Basic require ---

math-utils: require %lib/math-utils.ktg
math-utils/add 3 4                     ; => 7
math-utils/clamp 150 0 100             ; => 100

; --- Header introspection ---
; require/header returns the header block for inspection.
; The namespace is pure — no hidden words injected.

info: require/header %lib/math-utils.ktg
info/name                               ; => 'math-utils
info/version                            ; => 1.0.0
info/date                               ; => 2026-02-26

; --- Conditional require ---
; require is just a word. Use it anywhere you'd use any word.

platform-lib: either platform = 'windows [
  require %platform/windows.ktg
] [
  require %platform/linux.ktg
]

platform-lib/init

; --- Requiring dialects ---
; Dialects are just files. Require them, use them.

csv: require %dialects/csv.ktg
csv/parse %data/users.csv

html: require %dialects/html.ktg
html/render [
  head [title "Hello"]
  body [p "World"]
]

; --- What a module file looks like ---
; It's just a regular Kintsugi program. Nothing special.
; require reads the header, resolves modules:, then
; evaluates the rest in its own context.
;
; ; --- lib/math-utils.ktg ---
; Kintsugi [
;   name: 'math-utils
;   date: 2026-02-26
;   version: 1.0.0
; ]
;
; add: function [a [number!] b [number!]] [a + b]
; clamp: function [val [number!] lo [number!] hi [number!]] [
;   min hi max lo val
; ]
; _helper: function [x] [x * x]         ; convention: _ prefix = private

; --- Header modules: sugar ---
; Lit-words require built-in dialects. Files require modules.
; Each is bound to the name from its own header.
;
; Kintsugi [
;   modules: ['view %api.ktg]
; ]
;
; ...expands to roughly:
;
; view: require 'view          ; built-in dialect
; api: require %api.ktg        ; file module


; ============================================================
; PUTTING IT ALL TOGETHER
; ============================================================
; A small program that exercises several features at once.

fetch-users: function [url [url!] /max limit [integer!]] [
  attempt [
    do      [http/get url]
    then    [parse it/body [some [copy user to "^/" skip]]]
    then    [map it (u -> trim u)]
    then    [filter it (u -> not empty? u)]
    then    [either max [take it limit] [it]]
    retries 3
    delay   500
    on 'unreachable [print "retrying..." none]
    fallback [error 'fetch-failed "could not reach server"]
  ]
]

result: fetch-users https://example.com/users/max 10

loop [
  for [user index]
  in result
  scope/first [print "=== User List ==="]
  scope/last  [print "=== " + index + " users total ==="]
  do [
    match user [
      ["admin" _] [print "  * " + user + " (admin)"]
      [name]      [print "  - " + name]
    ]
  ]
]
