Kintsugi [name: 'pong]

; ============================================================
; Pong - love2d target.
;
; Demonstrates the @game dialect at its current shape:
; - constants block for compile-time inlined values
; - group 'main with state, entities, collide, draw
; - per-entity update blocks with self/<field> substitution
; - tag-based collide form (`collide ball 'paddle [...]`)
; - love/keypressed wired outside @game (input is target-native)
;
; Real reuse lives in user functions. `reset-ball` is plain
; Kintsugi - the dialect doesn't know about it. This is
; "compile-time EC, you supply the S" in practice: respawn is a
; system concern, so it's user code that the entity update calls.
;
; Pong does not exercise the heavier @game features (@template,
; destroy/alive?, collide/using) because pong's three entities
; have no shared behavior, no death, and rectangular collisions.
; They're documented in the bible and full-spec for games that do.
; ============================================================

; --- Helpers (user code, not dialect concerns) ---

reset-ball: function [b dir] [
  b/x: 396  b/y: 296
  b/dx: dir
  b/dy: 0
  b/speed: 350
]

; --- Game ---

@game [
  constants [
    SCREEN-W: 800
    SCREEN-H: 600
    PADDLE-SPEED: 420
    BALL-ACCEL: 20
    BALL-RADIUS: 8
  ]

  group 'main [
    state [
      paused?: false
      player-score: 0
      cpu-score: 0
    ]

    on-update [if paused? [return]]

    entity player [
      pos 20 260  rect 12 80  color 0.9 0.9 1
      tags [paddle]
      update [
        if love/keyboard/isDown "w" [self/y: self/y - (PADDLE-SPEED * dt)]
        if love/keyboard/isDown "s" [self/y: self/y + (PADDLE-SPEED * dt)]
      ]
    ]

    entity cpu [
      pos 768 260  rect 12 80  color 0.9 0.9 1
      tags [paddle]
      update [self/y: ball/y - 40]
    ]

    entity ball [
      pos 396 296  rect 8 8  color 1 0.8 0.2
      field dx 1
      field dy 0
      field speed 350
      update [
        ; Integrate position
        self/x: self/x + (self/dx * self/speed * dt)
        self/y: self/y + (self/dy * self/speed * dt)
        ; Wall bounce
        if self/y < 0 [
          self/y: 0
          self/dy: negate self/dy
        ]
        if self/y > (SCREEN-H - BALL-RADIUS) [
          self/y: SCREEN-H - BALL-RADIUS
          self/dy: negate self/dy
        ]
        ; Goal lines - score and respawn via the user helper
        if self/x < 0 [
          cpu-score: cpu-score + 1
          reset-ball self 1
        ]
        if self/x > SCREEN-W [
          player-score: player-score + 1
          reset-ball self -1
        ]
      ]
    ]

    collide ball 'paddle [
      ball/dx: negate ball/dx
      ball/dy: (ball/y - it/y) / 40
      ball/speed: ball/speed + BALL-ACCEL
    ]

    draw [
      love/graphics/print rejoin [player-score "   " cpu-score] 380 20
    ]
  ]

  go 'main
]

; --- Platform-specific input wiring (outside @game) ---
; Lives outside the @game block because input is target-native:
; this file is implicitly a love2d file by referencing
; love/keypressed.

love/keypressed: function [key] [
  match key [
    ["space"]  [paused?: not paused?]
    ["escape"] [love/event/quit]
    default    []
  ]
]
